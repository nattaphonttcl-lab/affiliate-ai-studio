# App settings (example) - copy to .env and fill values
PROJECT_NAME=Affiliate AI Studio - API
DEBUG=false

# Security
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (optional override - docker-compose sets DATABASE_URL for containers)
# DATABASE_URL=postgresql+asyncpg://affiliate_user:change_me@postgres:5432/affiliate_db
# Database
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/affiliate_db

# Security
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
PROJECT_NAME=Affiliate AI Studio - API
DEBUG=false
